      },
      "configuration" : {
        "scriptLang" : "JS",
        "jsScript" : "\r\n// Expect an array of related entities with telemetry in msg.data or msg.entities\r\nvar rows = msg.data || msg.entities || [];\r\nvar sum = 0;\r\nvar count = 0;\r\n\r\nrows.forEach(function (row) {\r\n  // Common formats: row.latest.TEMPERATURE[0].value or row.temperature.value\r\n  var t = null;\r\n\r\n  if (row.latest && row.latest.temperature && row.latest.temperature.length) {\r\n    t = row.latest.temperature[0].value;\r\n  } else if (row.temperature && row.temperature.value !== undefined) {\r\n    t = row.temperature.value;\r\n  } else if (row.temperature !== undefined) {\r\n    t = row.temperature;\r\n  }\r\n\r\n  t = Number(t);\r\n  if (!isNaN(t)) {\r\n    sum += t;\r\n    count += 1;\r\n  }\r\n});\r\n\r\nif (count === 0) return null;\r\n\r\nmsg = {\r\n  floor_avg_temperature: sum / count,\r\n  floor_avg_sample_count: count\r\n};\r\nreturn { msg: msg, metadata: metadata, msgType: 'POST_TELEMETRY_REQUEST' };",
