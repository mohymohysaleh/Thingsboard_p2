      "configuration" : {
        "scriptLang" : "TBEL",
        "jsScript" : "// Device name format: b01-f01-r101\r\n// Extract floor number from device name\r\nvar parts = originator.name.split('-');\r\n// parts[0] = b01, parts[1] = f01, parts[2] = r101\r\n\r\nvar floorNum = parseInt(parts[1].replace('f', ''));\r\nvar floorAssetName = 'Floor-' + (floorNum < 10 ? '0' + floorNum : '' + floorNum);\r\n\r\nmsg.floorAsset = floorAssetName;\r\nreturn {msg: msg, metadata: metadata, msgType: msgType};",
        "tbelScript" : "// Device name format: b01-f01-r101\r\n// Extract floor number from device name\r\nvar parts = originator.name.split('-');\r\n// parts[0] = b01, parts[1] = f01, parts[2] = r101\r\n\r\nvar floorNum = parseInt(parts[1].replace('f', ''));\r\nvar floorAssetName = 'Floor-' + (floorNum < 10 ? '0' + floorNum : '' + floorNum);\r\n\r\nmsg.floorAsset = floorAssetName;\r\nreturn {msg: msg, metadata: metadata, msgType: msgType};"
