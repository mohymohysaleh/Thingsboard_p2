                "showWidgetActionFunction" : "return true;",
                "type" : "custom",
                "customFunction" : "let $injector = widgetContext.$scope.$injector;\r\n\r\nlet rpcService = $injector.get(widgetContext.servicesMap.get('deviceService'));\r\n\r\nlet rpcRequest = { \r\n    method: 'hvac_mode', \r\n    params: 'eco' \r\n};\r\n\r\nrpcService.sendTwoWayRpcCommand(entityId.id, rpcRequest).subscribe(\r\n    function success(responseBody) {\r\n        widgetContext.showSuccessToast('HVAC turned ECO for ' + entityName);\r\n        console.log(\"Node-RED reply: \", responseBody);\r\n    },\r\n    function error(err) {\r\n        widgetContext.showErrorToast('Failed to command ' + entityName);\r\n        console.error(\"RPC Error: \", err);\r\n    }\r\n);",
